{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"],
      "@/pejay-ui/components/*": ["./templates/*"],
      "@/pejay-ui/utils/*": ["./utils/*"],
      "@/pejay-ui/panels": ["./templates/panels"],
      "@/pejay-ui/panels/*": ["./templates/panels/*"],
      "@/pejay-ui/hotkeys": ["./templates/hotkeys"],
      "@/pejay-ui/hotkeys/*": ["./templates/hotkeys/*"],
      "@/pejay-ui/spinner": ["./templates/spinner"],
      "@/pejay-ui/spinner/*": ["./templates/spinner/*"]
    },
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["templates/**/*", "utils/**/*"],
  "exclude": [
    "templates/scaffolds/**/*",
    "templates/utilities/**/*",
    "templates/notes/**/*"
  ]
}
